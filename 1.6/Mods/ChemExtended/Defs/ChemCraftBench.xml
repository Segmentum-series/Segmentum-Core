<?xml version="1.0" encoding="utf-8"?>
<Defs>
<!-- Reminder: The following defs need to be renamed from "Seg_COTO" to "Seg_" in future game version updates. -->

<!-- WorkGivers -->
	<!-- Ceramite furnace -->
	<WorkGiverDef>
		<defName>WorkGiver_CeramiteFurnaceChemfuel</defName>
		<label>operate ceramite furnace</label>
		<giverClass>WorkGiver_DoBill</giverClass>
		<workType>Smithing</workType>
		<priorityInType>80</priorityInType>
		<verb>smelt</verb>
		<gerund>smelting at</gerund>
		<requiredCapacities>
			<li>Manipulation</li>
		</requiredCapacities>
		<fixedBillGiverDefs>
			<li>Seg_COTO_CeramiteFurnaceChemfuel</li>
		</fixedBillGiverDefs>
		<prioritizeSustains>true</prioritizeSustains>
	</WorkGiverDef>

<!-- Buildings -->
	<!-- Ceramite furnace -->
	<ThingDef ParentName="BenchBase">
		<defName>Seg_COTO_CeramiteFurnaceChemfuel</defName>
		<label>ceramite furnace (chemfuel powered)</label>
		<tickerType>Normal</tickerType>
		<description>A small foundry, often used in settlements that require a constant but small supply of ceramite. Uses chemfuel rather than generated Motive Force to power its workings.</description>
		<thingClass>Building_WorkTable</thingClass>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
			<WorkToBuild>5000</WorkToBuild>
			<Flammability>1.0</Flammability>
		</statBases>
		<minifiedDef />
		<thingCategories Inherit="false" />
		<size>(3,2)</size>
		<costList>
			<Steel>120</Steel>
			<ComponentIndustrial>5</ComponentIndustrial>
		</costList>
		<comps>
			<li Class="PipeSystem.CompProperties_ResourceTrader">
				<pipeNet>VCHE_ChemfuelNet</pipeNet>
				<consumptionPerTick>1</consumptionPerTick>
				<idleConsumptionPerTick>0</idleConsumptionPerTick>
			</li>
			<li Class="CompProperties_Refuelable">
				<fuelCapacity>75.0</fuelCapacity>
				<fuelFilter>
					<thingDefs>
						<li>Chemfuel</li>
					</thingDefs>
				</fuelFilter>
				<initialFuelPercent>1</initialFuelPercent>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
			</li>
		
		<li Class="CompProperties_Flickable"/>
		<li Class="CompProperties_Breakdownable"/>
		<li Class="CompProperties_Glower">
				<glowRadius>6</glowRadius>
				<glowColor>(217,112,33,0)</glowColor>
			</li>
		</comps>
		<graphicData>
			<texPath>Things/Building/CeramiteFurnaceChemfuel/Seg_CeramiteFurnaceChemfuel</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(5,4)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>
		<inspectorTabs>
		<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<workTableRoomRole>Workshop</workTableRoomRole>
			<workTableNotInRoomRoleFactor>0.8</workTableNotInRoomRoleFactor>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
		</building>
		<fillPercent>0.5</fillPercent>
		<interactionCellOffset>(0,0,-1)</interactionCellOffset>
		<hasInteractionCell>true</hasInteractionCell>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<designationCategory>Production</designationCategory>
	
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<placeWorkers>
			<li>PlaceWorker_PreventInteractionSpotOverlap</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>Seg_CeramiteProduction</li>
		</researchPrerequisites>
		<modExtensions>
			<li Class="VEF.Buildings.RecipeInheritanceExtension">
				<inheritRecipesFrom>
					<li>Seg_COTO_CeramiteFurnace</li>
				</inheritRecipesFrom>
			</li>
		</modExtensions>
	</ThingDef>

</Defs>