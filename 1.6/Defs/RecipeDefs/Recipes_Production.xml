<!-- non-butcher way to get limbs out, needs to be  in core so please keep description saying that its a waste to -->
<RecipeDef>
    <defName>Seg_SERV_EthicalButchery</defName> <!--Directly called in c#, do not change unless you're recompiling the .cs and changing it there too-->
    <label>recover servitor parts</label>
    <description>use strong chemicals, cleavers and elbow grease to remove and clean the corpse, recovering serivtor parts. the harsh process strips the corpse of the ever-useful meat and leather, and just retrieves the servitor parts back. A waste, but certian not to upset people as much. Wasteful, if they have no parts to recover.</description>
    <jobString>Recovering Servitor Parts</jobString>
    <workAmount>800</workAmount>
    <workSpeedStat>ButcheryFleshSpeed</workSpeedStat>
    <workSkill>Cooking</workSkill>
    <efficiencyStat>ButcheryFleshEfficiency</efficiencyStat>
    <effectWorking>ButcherFlesh</effectWorking>
    <soundWorking>Recipe_ButcherCorpseFlesh</soundWorking>
    <interruptIfIngredientIsRotting>true</interruptIfIngredientIsRotting>
    <uiIconThing>Meat_Muffalo</uiIconThing>
    <ingredients>
        <li>
            <filter>
                <categories>
                    <li>CorpsesHumanlike</li>
                </categories>
            </filter>
            <count>1</count>
        </li>
    </ingredients>
    <fixedIngredientFilter>
        <categories>
            <li>CorpsesHumanlike</li>
        </categories>
    </fixedIngredientFilter>
    <products />
    <recipeUsers>
        <li>TableButcher</li>
    </recipeUsers>
</RecipeDef>
</Defs>