<Defs>

	<!-- Mars lasgun -->
	<ThingDef ParentName="BaseHumanMakeableGun">
		<defName>Seg_Gun_MarsLasgun</defName>
		<label>Lasgun (Mars-pattern)</label>
		<description>Like all lasguns, the Mars-pattern is not the most powerful firearm, but it is reliable, logistically simple, and can stop a charging greenskin at fifty paces with an accurate grouping of lasbolts. This is one of the oldest patterns of lasgun still in use in the Imperium, and is still frequently found in the hands of noble retinues or Inquisition warbands as well as seeing continuing use by forces supplied by the forge world of Mars.</description>
		<graphicData>
			<texPath>Things/Weapon/Seg_Ranged_MarsLasgun</texPath>
			<shaderType>Cutout</shaderType>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.3</drawSize>
		</graphicData>
		<!-- <uiIconScale>0.8</uiIconScale> Not working currently for unspecified reasons -->

		<recipeMaker>
			<researchPrerequisite Inherit="False"></researchPrerequisite>
			<researchPrerequisites Inherit="False">
				<li>Seg_MunitorumEquipment</li>
				<li>GasOperation</li>
				<li>Batteries</li>
			</researchPrerequisites>
			<recipeUsers Inherit="False">
				<li>Seg_ImperialCraftingTable</li>
				<li MayRequire="REDACTED.Segmentum.ChildrenOfTheOmnissiah">Seg_COTO_CraftingTable</li>
			</recipeUsers>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<skillRequirements>
				<Crafting>6</Crafting>
			</skillRequirements>
		</recipeMaker>
		<tools>
			<li>
				<label>stock</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<uiIconScale>1</uiIconScale>
		<statBases>
			<Mass>4</Mass>
			<EquipDelay>1.7</EquipDelay>
			<RangedWeapon_Cooldown>1.6</RangedWeapon_Cooldown>
			<AccuracyTouch>0.65</AccuracyTouch>
			<AccuracyShort>0.75</AccuracyShort>
			<AccuracyMedium>0.75</AccuracyMedium>
			<AccuracyLong>0.65</AccuracyLong>
			<WorkToMake>20000</WorkToMake>
			<MarketValue>650</MarketValue>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>Seg_MarsLasgunShot</defaultProjectile>
				<soundCast>Seg_LasgunFire</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<warmupTime>1.5</warmupTime>
				<range>31.9</range>
				<burstShotCount>2</burstShotCount>
				<ticksBetweenBurstShots>20</ticksBetweenBurstShots>
				<muzzleFlashScale>10</muzzleFlashScale>
			</li>
		</verbs>
		<costList>
			<Steel>70</Steel>
			<ComponentIndustrial>8</ComponentIndustrial>
		</costList>
		<modExtensions>
			<li Class="VEF.Things.ThingDefExtension">
				<weaponCarryDrawOffsets>
					<north>
						<angleOffset>0</angleOffset>
					</north>
					<east>
						<drawOffset>(0, 0, -0.1)</drawOffset>
					</east>
					<south>
						<angleOffset>0</angleOffset>
						<drawOffset>(0, 0, -0.1)</drawOffset>
					</south>
					<west>
						<drawOffset>(0, 0, -0.1)</drawOffset>
					</west>
				</weaponCarryDrawOffsets>
			</li>
			<li Class="Core40k.DefModExtension_AvailableDrawerTabDefs">
				<tabDefs>
					<li>BEWH_WeaponColoring</li>
					<li>BEWH_WeaponDecoration</li>
				</tabDefs>
			</li>
		</modExtensions>
		<comps>
				<li Class="Core40k.CompProperties_MultiColor">
					<colorMaskAmount>2</colorMaskAmount>
						<defaultPrimaryColor>(124,124,124)</defaultPrimaryColor>
						<defaultSecondaryColor>(140,85,57)</defaultSecondaryColor>
				</li>
				 <li Class="Core40k.CompProperties_WeaponDecoration" />
		</comps>
		<!-- Tags for trading and categorization for later-->
		<weaponTags Inherit="False">
			<li>Seg_Las</li>
		</weaponTags>
		<tradeTags Inherit="False">
			<li>Seg_Las</li>
		</tradeTags>
	</ThingDef>

</Defs>