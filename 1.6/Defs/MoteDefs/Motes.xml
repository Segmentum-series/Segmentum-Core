<Defs>

<!-- Lasgun -->
	<FleckDef ParentName="FleckBase">
		<defName>Seg_Lasgun_HitMote</defName>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<solidTime>0.06</solidTime>
		<fadeInTime>0.04</fadeInTime>
		<fadeOutTime>0.2</fadeOutTime>
		<growthRate>4</growthRate>
		<graphicData>
			<texPath>Things/Mote/BrightFlash</texPath>
			<shaderType>MoteGlow</shaderType>
			<color>(255,0,0)</color>
			<drawSize>.25</drawSize>
		</graphicData>
	</FleckDef>

	<FleckDef ParentName="FleckBase">
		<defName>Seg_Lasgun_HitMoteInterior</defName>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<solidTime>0.06</solidTime>
		<fadeInTime>0.04</fadeInTime>
		<fadeOutTime>0.2</fadeOutTime>
		<growthRate>4</growthRate>
		<graphicData>
			<texPath>Things/Mote/BrightFlash</texPath>
			<shaderType>MoteGlow</shaderType>
			<color>(255,255,255)</color>
			<drawSize>.15</drawSize>
		</graphicData>
	</FleckDef>

	<EffecterDef>
		<defName>Seg_Lasgun_HitEffecter</defName>
		<children>
			<!-- flash -->
			<li>
				<subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
				<fleckDef>Seg_Lasgun_HitMote</fleckDef>
				<burstCount>3</burstCount>
				<initialDelayTicks>1</initialDelayTicks>
				<chancePerTick>1</chancePerTick>
				<chancePeriodTicks>15</chancePeriodTicks>
				<scale>.3</scale>
				<spawnLocType>OnSource</spawnLocType>
			</li>

			<li>
				<subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
				<fleckDef>Seg_Lasgun_HitMoteInterior</fleckDef>
				<burstCount>3</burstCount>
				<initialDelayTicks>1</initialDelayTicks>
				<chancePerTick>1</chancePerTick>
				<chancePeriodTicks>15</chancePeriodTicks>
				<scale>.3</scale>
				<spawnLocType>OnSource</spawnLocType>
			</li>
		</children>
	</EffecterDef>

	<EffecterDef> <!-- Rename to "shooting effecter" -->
		<defName>Seg_Lasgun_LaserEffecter</defName>
		<children>
			<!-- <li>
				<subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
				<fleckDef>Seg_Lasgun_HitMote</fleckDef>
				<burstCount>3</burstCount>
				<initialDelayTicks>1</initialDelayTicks>
				<chancePerTick>1</chancePerTick>
				<chancePeriodTicks>15</chancePeriodTicks>
				<scale>.3</scale>
				<spawnLocType>OnSource</spawnLocType>
			</li>

			<li>
				<subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
				<fleckDef>Seg_Lasgun_HitMoteInterior</fleckDef>
				<burstCount>3</burstCount>
				<initialDelayTicks>1</initialDelayTicks>
				<chancePerTick>1</chancePerTick>
				<chancePeriodTicks>15</chancePeriodTicks>
				<scale>.3</scale>
				<spawnLocType>OnSource</spawnLocType>
			</li> -->

			<li>
				<subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
				<fleckDef>SparkFlash</fleckDef>
				<positionLerpFactor>0.7</positionLerpFactor>
				<chancePerTick>0.2</chancePerTick>
				<scale>
					<min>1</min>
					<max>4</max>
				</scale>
				<spawnLocType>OnSource</spawnLocType>
			</li>

			<li>
				<subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
				<positionRadius>0.04</positionRadius>
				<moteDef>Mote_SparkThrownFast</moteDef>
				<burstCount>
					<min>4</min>
					<max>5</max>
				</burstCount>
				<speed>
					<min>3</min>
					<max>5</max>
				</speed>
				<scale>
					<min>0.2</min>
					<max>0.4</max>
				</scale>
				<spawnLocType>OnSource</spawnLocType>
			</li>

			<li>
				<subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
				<positionRadius>0.02</positionRadius>
				<fleckDef>MicroSparksFast</fleckDef>
				<burstCount>
					<min>1</min>
					<max>1</max>
				</burstCount>
				<speed>
					<min>0.3</min>
					<max>0.4</max>
				</speed>
				<rotationRate>
					<min>5</min>
					<max>10</max>
				</rotationRate>
				<scale>
					<min>0.3</min>
					<max>0.5</max>
				</scale>
				<spawnLocType>OnSource</spawnLocType>
			</li>

			<li>
				<subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
				<positionRadius>0.1</positionRadius>
				<fleckDef>SparkFlash</fleckDef>
				<burstCount>
					<min>1</min>
					<max>1</max>
				</burstCount>
				<scale>
					<min>0.8</min>
					<max>1.5</max>
				</scale>
				<spawnLocType>OnSource</spawnLocType>
			</li>

			<li>
				<subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
				<fleckDef>Smoke</fleckDef>
				<ticksBetweenMotes>30</ticksBetweenMotes>
				<scale>0.8~1.2</scale>
				<spawnLocType>OnSource</spawnLocType>
				<absoluteAngle>true</absoluteAngle>
				<angle>30~70</angle>
				<speed>0.2~0.35</speed>
			</li>

			<li>
				<subEffecterClass>SubEffecter_SprayerContinuous</subEffecterClass>
				<fleckDef>Smoke</fleckDef>
				<ticksBetweenMotes>15</ticksBetweenMotes>
				<scale>0.8~1.2</scale>
				<spawnLocType>OnSource</spawnLocType>
				<absoluteAngle>true</absoluteAngle>
				<angle>30~70</angle>
				<speed>0.2~0.35</speed>
				
			</li>
		</children>

		<offsetTowardsTarget>
			<min>1</min>
			<max>1</max>
		</offsetTowardsTarget>

		<positionRadius>0.02</positionRadius>
	</EffecterDef>

<!-- Plasma -->
	<FleckDef ParentName="FleckBase_Thrown">
		<defName>SEG_COTO_Plasmafleksplatter</defName>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<fadeInTime>0.05</fadeInTime>
		<fadeOutTime>0.5</fadeOutTime>
		<solidTime>0.8</solidTime>
		<growthRate>0</growthRate>
		<graphicData>
		<texPath>Things/Projectile/Seg_COTO_Plasma_trail</texPath>
			<graphicClass>Graphic_FleckPulse</graphicClass>
			<color>(1, 1, 1, 0.70)</color>
			<shaderType>TransparentPostLight</shaderType>
			<shaderParameters>
				<_MultiplyTex>1</_MultiplyTex>
				<_texBScale>0.2</_texBScale>
				<_texBScrollSpeed>-0.5</_texBScrollSpeed>
				<_Intensity>13</_Intensity>
				<_Clip>0</_Clip>
			</shaderParameters>
			<drawSize>(2, 2)</drawSize>
		</graphicData>
	</FleckDef>

<!-- Blast EMP long -->
	<FleckDef ParentName="FleckBase">
		<defName>Seg_BlastEMPLong</defName>
		<graphicData>
			<texPath>Things/Mote/BlastEMP</texPath>
			<shaderType>TransparentPostLight</shaderType>
			<renderInstanced>true</renderInstanced>
		</graphicData>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<solidTime>.5</solidTime>
		<fadeOutTime>0.2</fadeOutTime>
	</FleckDef>
</Defs>